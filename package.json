{
  "name": "flint", "productName": "Flint", "version": "1.5.1", "description": "Flint, a quiet, private daily journal. Your notes never leave this computer.", "main": "main.js", "license": "MIT", "private": true, "scripts": {
    "start": "electron .", "test": "node tests/store.test.js", "smoke:pdf": "electron scripts/pdf-smoke.js", "smoke:updater": "electron scripts/updater-smoke.js", "smoke:tray": "electron scripts/tray-smoke.js", "dist:build": "electron-builder --win",
    "dist": "npm run dist:build && npm run check:package", "check:package": "node scripts/check-package.js", "check:mutation": "node scripts/mutation-check.js", "publish": "npm run dist && electron-builder --win --publish always"
  }, "build": {
    "appId": "com.local.flint", "productName": "Flint", "directories": {
      "output": "dist"
    }, "artifactName": "Flint-Setup-${version}.${ext}", "electronFuses": {
      "runAsNode": false,
      "enableNodeOptionsEnvironmentVariable": false,
      "enableNodeCliInspectArguments": false,
      "enableEmbeddedAsarIntegrityValidation": true,
      "onlyLoadAppFromAsar": true
    }, "files": [
      "**/*", "!tests/**/*", "!scripts/**/*", "!dist/**/*", "!**/*.md", "!.gitignore", "!*.bat", "!.hallmark/**/*", "!.claude/**/*", "!.github/**/*", "!.vscode/**/*", "!.idea/**/*", "!**/*.lock", "!**/.env*"
    ], "publish": [
      {
        "provider": "github", "owner": "Bordder", "repo": "Flint"
      }
    ], "win": {
      "target": "nsis", "icon": "assets/icon.ico"
    }, "nsis": {
      "oneClick": true, "perMachine": false, "createDesktopShortcut": true, "createStartMenuShortcut": true, "deleteAppDataOnUninstall": false
    }
  }, "dependencies": {
    "electron-updater": "^6.8.9"
  }, "devDependencies": {
    "electron": "^43.1.1", "electron-builder": "^26.15.3"
  }
}
